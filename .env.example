DATABASE_URL=postgresql+psycopg2://cmsplus:cmsplus@localhost:5432/cmsplus

# Oturum çerezini imzalamak için kullanılır - rastgele, uzun bir değer olmalı (ör. `python -c "import secrets; print(secrets.token_hex(32))"`)
SECRET_KEY=

# Cron job bildirimleri için e-posta (opsiyonel) - SMTP_HOST boşsa e-posta gönderilmez, sadece loglanır.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# Bildirim e-postalarındaki linklerin işaret edeceği adres
BASE_URL=http://localhost:8000
